{
  "compilerOptions": {
    "target": "es2021",
    "lib": ["es2021"],
    "alwaysStrict": true,
    "strict": true,
    "preserveConstEnums": true,
    "module": "es2022",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": [
      "@cloudflare/workers-types"
    ]
  },
  "exclude": ["node_modules", "dist"]
}
